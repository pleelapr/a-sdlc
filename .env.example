# =============================================================================
# a-sdlc Docker Compose — Environment Variables
# =============================================================================
# Copy this file to .env and edit with your values:
#   cp .env.example .env
#
# All variables have sensible defaults for local development.
# Ports use 19xxx range to avoid conflicts with other services.
# For production, change ALL passwords and secrets.
# =============================================================================

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=asdlc
POSTGRES_PASSWORD=asdlc_dev
POSTGRES_DB=asdlc
POSTGRES_PORT=19432

# --- MinIO (S3-compatible storage) --------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

# --- a-sdlc server -----------------------------------------------------------
# Database connection (constructed from Postgres vars in docker-compose.yml)
# Override only if connecting to an external database:
# A_SDLC_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Content backend: 'local' (filesystem) or 's3' (MinIO/S3)
# A_SDLC_CONTENT_BACKEND=s3

# S3/MinIO settings (defaults match MinIO service above)
A_SDLC_S3_BUCKET=asdlc-content
# A_SDLC_S3_ENDPOINT=http://minio:9000
# A_SDLC_S3_ACCESS_KEY=minioadmin
# A_SDLC_S3_SECRET_KEY=minioadmin

# HTTP ports exposed by the a-sdlc server
A_SDLC_MCP_PORT=19765
A_SDLC_UI_PORT=19847

# --- Schema migrations -------------------------------------------------------
# Alembic 'upgrade head' runs automatically at server startup (before storage
# init) and is fatal on failure. Set to 0/false to skip (emergency ops only;
# then run 'a-sdlc db migrate' manually).
# A_SDLC_AUTO_MIGRATE=1
